{
  "name": "Wonderful Wino",
  "version": "0.0.4",
  "slug": "wonderful_wino",
  "description": "Access your wines from Home Assistant ToDo list. Yes, a quick nod to both George Carlin and the Mothers of Invention",
  "url": "https://github.com/frankjaco/homeassistant-wwino-addon",
  "icon": "WW-icon.png",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "init": false,
  "boot": "auto",
  "host_network": true,
  "map": ["share:rw"],
  "options": {
    "HOME_ASSISTANT_URL": "http://homeassistant.local:8123",
    "HA_LONG_LIVED_TOKEN": "",
    "TODO_LIST_ENTITY_ID": "todo.my_wine",
    "LOG_LEVEL": "info",
    "DANGER! Setting to ON and starting the Addon will RESET your Database completely! REMEMBER to turn the switch OFF after use!!!": false
  },
  "schema": {
    "HOME_ASSISTANT_URL": "str",
    "HA_LONG_LIVED_TOKEN": "str",
    "TODO_LIST_ENTITY_ID": "str",
    "LOG_LEVEL": "list(debug|info|warning|error|critical)",
    "REINITIALIZE_DATABASE": "bool"
  },
  "ports": {
    "5000/tcp": null
  },
  "ports_description": {
    "5000/tcp": "Flask application HTTP port"
  },
  "webui": "http://[HOST]:[PORT:5000]"
}
