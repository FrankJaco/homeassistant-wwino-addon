{
  "name": "Wonderful Wino",
  "version": "0.0.2",
  "slug": "wine_inventory_scanner",
  "description": "Track your wine collection and sync it with your Home Assistant ToDo list. Yes a quick wink and nod to George Carlin and the Mothers of Invention as well",
  "url": "https://github.com/FrankJaco/homeassistant-wwino-addon",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "init": false,
  "boot": "auto",
  "host_network": true,
  "map": ["share:rw"],
  "options": {
    "HOME_ASSISTANT_URL": "http://homeassistant.local:8123",
    "HA_LONG_LIVED_TOKEN": "",
    "TODO_LIST_ENTITY_ID": "todo.wine_fridge_contents",
    "LOG_LEVEL": "info"
  },
  "schema": {
    "HOME_ASSISTANT_URL": "str",
    "HA_LONG_LIVED_TOKEN": "str",
    "TODO_LIST_ENTITY_ID": "str",
    "LOG_LEVEL": "list(debug|info|warning|error|critical)"
  },
  "ports": {
    "5000/tcp": null
  },
  "ports_description": {
    "5000/tcp": "Flask application HTTP port"
  },
  "webui": "http://[HOST]:[PORT:5000]"
}
